# ============================================
# Telegram Memory App - Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# --------------------------------------------
# REQUIRED - API Keys
# --------------------------------------------

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenAI API Key (for transcription and summarization)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# --------------------------------------------
# SERVER Configuration
# --------------------------------------------

# Port for the backend server
PORT=3000

# Environment: development or production
NODE_ENV=production

# Database path (SQLite)
DATABASE_PATH=./data/memory.db

# --------------------------------------------
# PRODUCTION - Domain & Webhook
# --------------------------------------------

# Your domain (for Telegram webhook)
# Example: https://famories.info
WEBHOOK_URL=https://famories.info

# --------------------------------------------
# SECURITY - Web App Password Protection
# --------------------------------------------

# Shared family password for web app access
# If not set, web app is open (no password required)
# Example: WEB_PASSWORD=family2024!
WEB_PASSWORD=

# --------------------------------------------
# OPTIONAL - Access Control
# --------------------------------------------

# Allowed Telegram Chat IDs (comma-separated)
# Leave empty to allow all chats (open mode)
# Find chat IDs in bot logs when users send /start
# Example: ALLOWED_TELEGRAM_CHAT_IDS=123456789,987654321
ALLOWED_TELEGRAM_CHAT_IDS=

# --------------------------------------------
# OPTIONAL - AI Services
# --------------------------------------------

# Gemini API Key (for logo generation - optional)
GEMINI_API_KEY=
