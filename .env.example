# Telegram Bot Token
# Bekommst du von @BotFather in Telegram
TELEGRAM_BOT_TOKEN=dein_telegram_bot_token_hier

# OpenAI API Key
# Bekommst du von https://platform.openai.com/api-keys
OPENAI_API_KEY=dein_openai_api_key_hier

# Server Konfiguration
PORT=3000

# Webhook URL (deine öffentliche URL, z.B. von ngrok)
# Wird später für die Telegram-Webhook-Registrierung benötigt
WEBHOOK_URL=https://deine-domain.com

# Datenbank
DATABASE_PATH=./data/memory.db
